<% layout("layouts/boilerplate") %>

    <style>
        .filters {

            display: flex;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter {

            margin-right: 2rem;
            text-align: center;
            cursor: pointer;
            opacity: 0.7;
            font-size : 0.8rem;
        }

        .filter:hover {
            opacity: 1;
        }

        .tax-toggle {
            border: 1px solid black;
            padding : 0.8rem;
            border-radius: 1rem;
            font-size: 0.9rem;
            margin-left: auto;
            margin-bottom:1rem;
        }
        .tax-info{

              display : none;
        }
    </style>

    <div class="filters  mt-3">

        <div class="filter mr-3">

            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </div>
        <div class="filter mr-3">

            <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
        </div>
        <div class="filter mr-3">

            <i class="fa-solid fa-mountain-city"></i>
            <p>Iconic Cities</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-mountain"></i>
            <p>Mountain</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-person-swimming"></i>
            <p>Amazing Pools</p>
        </div>

        <div class="filter">

            <i class="fa-sharp-duotone fa-regular fa-snowflake"></i>
            <p>Arctic</p>
        </div>
        <div class="filter">

            <i class="fa-brands fa-fort-awesome"></i>
            <p>Castle</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-cow"></i>
            <p>Farms</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-landmark-dome"></i>
            <p>Domes</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-sailboat"></i>
            <p>Boats</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </div>
        <div class="filter">

            <i class="fa-solid fa-person-skiing"></i>
            <p>Skiing</p>
        </div>


        <div class="tax-toggle">
            <div class="form-check form-switch form-check-reverse">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">
                    Prices Without Taxes
                </label>
            </div>
         </div>
    </div>

    <form method="GET" action="listings/new">
    </form>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">


        <% for (let i=0; i < allListings.length; i++) { %>

            <div class="col">

                <a href="/listings/<%= allListings[i]._id %>" class="image-link">


                    <div class="card listing-card">
                        <img src="<%= allListings[i].image.url %>" class="card-img-top">

                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= allListings[i].title %>
                                </b> <br>
                                &#8364;<%= allListings[i].price.toLocaleString("en-IN") %>/night 
                                <i class="tax-info">&nbsp; &nbsp; +18% GST</i>
                                <br>
                                    <!-- <%= allListings[i].description %> -->
                            </p>
                        </div>
                    </div>
                </a>


            </div>

            <% } %>

    </div>

     <script>

           let  taxSwitch = document.getElementById("switchCheckDefault");

           taxSwitch.addEventListener("click", ()=>{

                let information = document.getElementsByClassName("tax-info");

                 for(info of information){
      
                      if(info.style.display == "inline"){
      
                            info.style.display = "none";
                      }else{
                            info.style.display = "inline";
                      }
                 }
           });

     </script>