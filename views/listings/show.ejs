<% layout("layouts/boilerplate") %>

        <div class="row">

                <div class="col-8 offset-3 mt-3">


                        <h3>
                                <%= listing.title %>
                        </h3>

                </div>


                <div class="card col-6 offset-3 listing-card">
                        <img src="<%= listing.image.url %>" class="card-img-show">

                        <div class="card-body">
                                <p class="card-text">
                                        <!-- <b><%= listing.title %></b><br> -->
                                        <i>owned by <%= listing.owner.username %></i>
                                        <br>
                                        <b>
                                                <%= listing.description %>
                                        </b>
                                        <br>
                                        <b>&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
                                        </b>
                                        <br>
                                        <b>
                                                <%= listing.country %>
                                        </b><br>
                                        <b>
                                                <%= listing.location %>
                                        </b>
                                        <br>
                                </p>
                        </div>
                </div>


                <br><br>


        </div>

        <% if(curUser && curUser._id.equals(listing.owner._id)) { %>

                <div class="btns">

                        <a href="/listings/<%= listing._id %>/edit " class="btn btn-dark offset-3 col-1"> Edit </a>

                        <br>

                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                                <button class="btn btn-dark offset-3">
                                        Delete
                                </button>
                        </form>

                </div>

                <% } %>
                        <br>

                        <% if (listing) { %>
                                <div id="map" data-coordinates='<%- JSON.stringify(
            listing.geometry?.coordinates || [77.2090, 28.6139]
        ) %>' class="col-8 offset-3">
                                </div>
                                <% } %>

                                        <div class="col-8 offset-3">

                                                <% if(curUser) { %>


                                                        <hr>

                                                        <h4>Leave a Review </h4>
                                                        <h6>Rating </h6>

                                                        <form method="POST"
                                                                action="/listings/<%= listing._id %>/reviews" novalidate
                                                                class="needs-validation">

                                                                <!-- <div class="mb-3">
                                <label for="user" class="form-label"></label>
                                <input type="text" id = "user" name="review[user]" class="form-control">

                        </div> -->


                                                                <fieldset class="starability-slot" class="mb-3">
                                                                        <input type="radio" id="no-rate"
                                                                                class="input-no-rate"
                                                                                name="review[rating]" value="1" checked
                                                                                aria-label="No rating." />
                                                                        <input type="radio" id="first-rate1"
                                                                                name="review[rating]" value="1" />
                                                                        <label for="first-rate1" title="Terrible">1
                                                                                star</label>
                                                                        <input type="radio" id="first-rate2"
                                                                                name="review[rating]" value="2" />
                                                                        <label for="first-rate2" title="Not good">2
                                                                                stars</label>
                                                                        <input type="radio" id="first-rate3"
                                                                                name="review[rating]" value="3" />
                                                                        <label for="first-rate3" title="Average">3
                                                                                stars</label>
                                                                        <input type="radio" id="first-rate4"
                                                                                name="review[rating]" value="4" />
                                                                        <label for="first-rate4" title="Very good">4
                                                                                stars</label>
                                                                        <input type="radio" id="first-rate5"
                                                                                name="review[rating]" value="5" />
                                                                        <label for="first-rate5" title="Amazing">5
                                                                                stars</label>
                                                                </fieldset>


                                                                <div class="mb-3">

                                                                        <label for="comment" class="form-label"></label>
                                                                        <textarea name="review[comment]" id="comment"
                                                                                placeholder="add comment...." rows="5"
                                                                                cols="5" class="form-control"
                                                                                required></textarea>
                                                                        <div class="invalid-feedback">Please Write the
                                                                                Comment</div>
                                                                </div>

                                                                <button class="btn btn-dark mb-3"
                                                                        type="submit">submit</button>
                                                        </form>

                                                        <hr>

                                                        <%} %>

                                                                <p><b>All Reviews </b></p>

                                                                <div class="row">

                                                                        <% for(review of listing.reviews) { %>

                                                                                <div class="card col-5 ms-3 mb-3 ">

                                                                                        <div class="card-body">

                                                                                                <div
                                                                                                        class="d-flex justify-content-between align-items-center">
                                                                                                        <h5
                                                                                                                class="card-title mb-0">
                                                                                                                @ <%= review.author.username
                                                                                                                        %>
                                                                                                        </h5>

                                                                                                        <small
                                                                                                                class="text-muted">
                                                                                                                <%= review.CreatedAt.toLocaleDateString("en-GB",
                                                                                                                        {
                                                                                                                        day: "numeric"
                                                                                                                        ,
                                                                                                                        month: "short"
                                                                                                                        ,
                                                                                                                        year
                                                                                                                        : "numeric"
                                                                                                                        })
                                                                                                                        %>
                                                                                                        </small>
                                                                                                </div>
                                                                                                <p class="starability-result"
                                                                                                        data-rating="<%= review.rating %>"
                                                                                                        class="card-text">

                                                                                                </p>
                                                                                                <p class="card-text">
                                                                                                        <%= review.comment
                                                                                                                %>
                                                                                                </p>

                                                                                        </div>

                                                                                        <% if(review.author &&
                                                                                                review.author._id.equals(curUser._id))
                                                                                                { %>


                                                                                                <form class="mb-3 mt-3"
                                                                                                        method="POST"
                                                                                                        action="/listings/<%= listing._id%>/reviews/<%= review._id%>?_method=DELETE">

                                                                                                        <button type="submit"
                                                                                                                class="btn btn-sm btn-dark">Delete</button>
                                                                                                </form>

                                                                                                <% } %>


                                                                                </div>

                                                                                <% } %>

                                                                </div>
                                        </div>